{% extends "base.twig" %}

{% block before_head %}
  <!-- home.twig -->
{% endblock %}

{% block hero %}
  {% if pageBannerImg != ''
    or cssPageBannerColourCast != ''
    or pageSettingsShowSiteHero == true
    or (fn('is_front_page') and pageSettingsHideSiteHero != true )
  %}
    <section id="siteHero" class="l-site__hero{{ templateClass }}">
      {% include 'inc/hero.twig' ignore missing %}
    </section>
    {% else %}
    <!-- No hero -->
  {% endif %}
{% endblock %}

{% block before_main %}
  <section class="l-main-before--blog">
    {% if not hidePageTitle %}
      <div class="l-main-before__header--blog ">
        {% include "inc/header.twig"
          with {
          headingLevel : '1' ,
          headerModClass : '--blog'
        }%}
      </div>
    {% endif %}
      {% if post.content %}
        <div class="l-main-before__content--blog ">
          {{ post.content }}
        </div>
      {% endif %}
      <div class="l-main-before__nav-menu--blog">
        {% set menuName = "categories" %}
        {% set menuTitle = "Categories" %}
        {% include 'inc/navigation.twig' %}
      </div>


    {#    <div class="l-main-before__widget-area">#}
    {#      {% include 'inc/widget-area.twig' with {'widgetContainer' : 'main-before'}%}#}
    {#    </div>#}

  </section>


{% endblock %}


    {% block content %}
      <div class="l-post-thumb-list">
        <div class="l-post-thumb-list__list--column">
              {% for post in posts %}
                <div class="l-post-thumb-list__item--column">
                  <div class="l-post-thumb-list__post-thumb">
                      {% set postFormat = fn('get_post_format', post)? '-'~fn('get_post_format', post) : '' %}
                      {% include ['content/content'~postFormat~'.twig', 'content/content.twig'] %}
                  </div>
                </div>
              {% endfor %}
        </div>
      </div>
    {% endblock %}



{% block after_content %}
  <div class="content__below">
    {% if posts.pagination.pages is not empty %}
    <div class="content__pagination">
      {% include 'inc/pagination.twig' with { pagination: posts.pagination({show_all: false, mid_size: 3, end_size: 2}) } %}
    </div>
    {% endif %}
  </div>
  <!-- removed comments in home.twig -->
{% endblock %}

{% set hasSideBar = false %}

{% block sidebar %}

{% endblock %}
