<section id="comments" class="l-comments">
  <div class="l-comments__wrapper--responses">
    <div class="l-comments__responses">
      <div class="l-responses-list">
        <h3 class="l-responses-list__heading">{{ function('__', 'Comments', '_act') }}</h3>
        {% if post.comment_count > 0 %}
          <ol class="l-responses-list__list">
            {% for cmt in post.comments %}
              <li class="l-responses-list__item">
                <div class="l-responses-list__comment">

                  {% include "inc/comment.twig" with {comment:cmt} %}

                </div>

              </li>
            {% endfor %}
          </ol>
          {% else %}
          <p>{{ function('__', 'Be the first to leave a comment!', '_act') }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="l-comments__wrapper--comment-form">
    <div class="c-contact-form--comment-form">
      <h3 class="c-contact-form__heading--comment-form">{{ function('__', 'Submit a comment', '_act') }}</h3>
    {% if post.comment_status == "closed" %}
      <p>{{ function('__', 'comments for this post are closed', '_act') }}</p>
    {% else %}
      <!-- comment form -->
      {% include "inc/comment-form.twig" %}
    {% endif %}
    </div>
  </div>
</section>