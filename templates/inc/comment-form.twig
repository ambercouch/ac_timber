

    <form class="c-contact-form__form--comment-form" method="post" action="{{ site.site_url~'/wp-comments-post.php' }}">
      <div class="c-contact-form__content--comment-form" >
        {% if  user %}
            <input type="hidden" name="email" value="{{ user.email }}">
            <input type="hidden" name="author" value="{{ user.name }}">
            <input type="hidden" name="url" value="{{ user.link }}">
        {% else %}
            <label class="c-contact-form__label">
              <span class="c-contact-form__label-text" >{{ function('__', 'Email', '_act') }}</span>
              <span class="c-contact-form__input-wrapper" >
                <input class="c-contact-form__input--comment-form" placeholder="Email" required name="email" type="email" id="email">
              </span>
              <div class="c-contact-form__label-notes"><small>{{ function('__', 'Your email will not be published', '_act') }}</small></div>
            </label>
            <label class="c-contact-form__label">
              <span class="c-contact-form__label-text" >{{ function('__', 'Name', '_act') }}</span>
              <span class="c-contact-form__input-wrapper" >
                <input class="c-contact-form__input--comment-form" placeholder="Name"  required name="author" type="text">
              </span>
            </label>
            <label class="c-contact-form__label">
              <span class="c-contact-form__label-text" >{{ function('__', 'Website', '_act') }}</span>
              <span class="c-contact-form__input-wrapper" >
                <input class="c-contact-form__input--comment-form" placeholder="Website" name="url" type="url">
              </span>
            </label>
        {% endif %}
        <label class="c-contact-form__label--comment-form-textarea">
          <span class="c-contact-form__label-text" >{{ function('__', 'Comment', '_act') }}</span>
            <textarea class="c-contact-form__input--comment-form" placeholder="{{ function('__', 'Leave a comment...', '_act') }}" name="comment" cols="60" rows="3"></textarea>
        </label>
        <input name="comment_post_ID" value="{{ post.id }}" type="hidden">
        <input name="comment_parent"  value="{{ comment.ID|default('0') }}" type="hidden">
        <div class="c-contact-form__input-wrapper--submit" >
        <input class="c-contact-form__input--comment-form-submit c-btn__input--primary" type="submit" name="Post comment" class="btn">
        </div>
        <div class="c-contact-form__input-wrapper--comment-cancel" >
        <button class="c-btn--cancel-comment" type="reset">{{ function('__', 'Cancel', '_act') }}</button>
        </div>
{#        <p>Your comment will be revised by the site if needed.</p>#}
      </div>
    </form>

